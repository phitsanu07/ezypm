{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "compiled/api",
    "rootDir": "src",
    "noEmit": false,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false
  },
  "include": ["src/api/**/*", "src/types/**/*"]
}
