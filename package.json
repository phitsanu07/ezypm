{
  "name": "ezypm",
  "version": "0.1.0",
  "private": true,
  "description": "GridWork — Project Management ที่ใช้เหมือน Excel (Supabase + Express + Gemini)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,fe -c blue,magenta \"npm:dev:api\" \"npm:dev:fe\"",
    "dev:fe": "vite",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "npm run build:api && npm run build:fe",
    "build:fe": "vite build",
    "build:api": "tsc -p tsconfig.api.json",
    "preview": "vite preview",
    "start": "node dist/api/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:print": "echo 'Run supabase/migrations/*.sql via Supabase Dashboard SQL Editor (or supabase db push)'"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.46.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
