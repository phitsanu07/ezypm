{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:api && npm run build:fe",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "compiled/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
