{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:fe",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
